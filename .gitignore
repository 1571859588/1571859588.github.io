# Ignore the contents of the _site directory and other cache directories
_site/
.sass-cache/

# Ignore the directory for local files during development
local/

# Ignore the Gemfile that is generated
Gemfile.lock

# Ingore files created by npm
node_modules
package-lock.json

poe_adapter.py

others_blogs_sites/

_posts/*-cn.md

# video extract utils
videos/
.cache/
chi_sim.traineddata
eng.traineddata
.claude/settings.local.json
tools/extract-video-text.mjs

# NOTES source directory — only track .md and .assets/ (images)
